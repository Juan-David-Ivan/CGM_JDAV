<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CGM_JDAV.ViewModels"
             xmlns:p1="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
             mc:Ignorable="d"
             d:DesignWidth="340"
             Width="340"
             x:DataType="vm:MenuPrincipalViewModel"
             x:Class="CGM_JDAV.Views.Dialogs.PacienteDialog">
    <Design.DataContext>
        <vm:MenuPrincipalViewModel />
    </Design.DataContext>
     <Border Background="White" CornerRadius="8" Padding="8">
        <StackPanel Margin="4">
            <TextBlock Text="NUEVO PACIENTE"
                       HorizontalAlignment="Center"
                       Margin="10"
                       FontSize="22"
                       FontWeight="Black"
                       Foreground="#1B3A7A"/>

            <TextBox Theme="{StaticResource FilledTextBox}"
                     Watermark="Ej: Lucía"
                     UseFloatingWatermark="True"
                     p1:TextFieldAssist.Label="Nombre"
                     Margin="10,4"
                     Text="{Binding PacienteSeleccionado.Nombre}"/>

            <TextBox Theme="{StaticResource FilledTextBox}"
                     Watermark="Ej: Martínez"
                     UseFloatingWatermark="True"
                     p1:TextFieldAssist.Label="Apellido"
                     Margin="10,4"
                     Text="{Binding PacienteSeleccionado.Apellido}"/>

            <TextBox Theme="{StaticResource FilledTextBox}"
                     Watermark="Ej: 12345678A"
                     UseFloatingWatermark="True"
                     p1:TextFieldAssist.Label="DNI"
                     Margin="10,4"
                     Text="{Binding PacienteSeleccionado.Dni}"/>

            <TextBox Theme="{StaticResource FilledTextBox}"
                     Watermark="Ej: PAC-001"
                     UseFloatingWatermark="True"
                     p1:TextFieldAssist.Label="Identificador"
                     IsReadOnly="True"
                     Margin="10,4"
                     Text="{Binding PacienteSeleccionado.Identificador}"/>

            <TextBlock Text="Fecha de nacimiento"
                       Margin="10,8,10,0"
                       FontWeight="SemiBold"
                       Foreground="#1B3A7A"/>
            <DatePicker Margin="10,4"
                        HorizontalAlignment="Stretch"
                        SelectedDate="{Binding FechaNacimientoSel}"/>

            <TextBox Theme="{StaticResource FilledTextBox}"
                     Watermark="Ej: lucia@correo.com"
                     UseFloatingWatermark="True"
                     p1:TextFieldAssist.Label="Correo electrónico"
                     Margin="10,4"
                     Text="{Binding PacienteSeleccionado.CorreoElectronico}"/>
            
            <TextBlock Text="{Binding MensajeErrorDialog}"
                       Foreground="Red"
                       FontSize="12"
                       Margin="10,4"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding HayErrorDialog}"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="10">
                <Button Content="AÑADIR"
                        Margin="10"
                        Width="120"
                        Background="DarkGreen"
                        Foreground="White"
                        Command="{Binding GuardarPacienteCommand}"/>
                <Button Content="CANCELAR"
                        Margin="10"
                        Width="120"
                        Background="DarkRed"
                        Foreground="White"
                        Command="{Binding ClosePacienteDialogCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>